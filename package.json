{
  "name": "playwright-kriso",
  "version": "1.0.0",
  "description": "E2E test automation for Kriso.ee webshop using Playwright",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "codegen": "playwright codegen https://www.kriso.ee",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  }
}
